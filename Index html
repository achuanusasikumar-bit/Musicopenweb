<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OpenMusic - Free & Ad-Free</title>
    <style>
        :root {
            --bg-color: #121212;
            --surface-color: #282828;
            --primary-color: #1db954;
            --primary-hover: #1ed760;
            --text-main: #ffffff;
            --text-muted: #b3b3b3;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .container {
            width: 100%;
            max-width: 600px;
            background-color: var(--surface-color);
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        }
        h1 {
            text-align: center;
            margin-top: 0;
            color: var(--primary-color);
            letter-spacing: 1px;
        }
        .player-controls {
            width: 100%;
            margin-bottom: 25px;
            background: #181818;
            padding: 20px;
            border-radius: 8px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        #current-track-title {
            margin-top: 0;
            margin-bottom: 15px;
            font-size: 1.1em;
            text-align: center;
        }
        audio {
            width: 100%;
            outline: none;
            margin-bottom: 15px;
        }
        
        /* New Download Button Styles */
        .action-buttons {
            display: flex;
            gap: 10px;
            width: 100%;
        }
        .btn {
            flex: 1;
            padding: 10px 15px;
            border: none;
            border-radius: 20px;
            font-weight: bold;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            transition: background 0.2s, transform 0.1s;
        }
        .btn:active {
            transform: scale(0.98);
        }
        .btn-download {
            background-color: var(--primary-color);
            color: #000;
        }
        .btn-download:hover {
            background-color: var(--primary-hover);
        }
        .btn-disabled {
            background-color: #555;
            color: #888;
            cursor: not-allowed;
            pointer-events: none;
        }

        .playlist-header {
            font-size: 1.2em;
            margin-bottom: 10px;
            border-bottom: 2px solid #333;
            padding-bottom: 10px;
            display: flex;
            justify-content: space-between;
        }
        .playlist {
            list-style: none;
            padding: 0;
            margin: 0;
            max-height: 400px;
            overflow-y: auto;
        }
        .playlist::-webkit-scrollbar { width: 8px; }
        .playlist::-webkit-scrollbar-track { background: #1e1e1e; }
        .playlist::-webkit-scrollbar-thumb { background: #555; border-radius: 4px; }
        .playlist::-webkit-scrollbar-thumb:hover { background: var(--primary-color); }
        
        .playlist li {
            padding: 15px;
            border-bottom: 1px solid #333;
            cursor: pointer;
            transition: background 0.2s, padding-left 0.2s;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-radius: 4px;
        }
        .playlist li:hover { background-color: #3e3e3e; padding-left: 20px; }
        .playlist li.active {
            background-color: #1a1a1a;
            color: var(--primary-color);
            font-weight: bold;
            border-left: 4px solid var(--primary-color);
        }
        .song-info { display: flex; flex-direction: column; }
        .artist-name { font-size: 0.85em; color: var(--text-muted); margin-top: 4px; font-weight: normal; }
    </style>
</head>
<body>

    <div class="container">
        <h1>OpenMusic</h1>
        
        <div class="player-controls">
            <h3 id="current-track-title">Select a track to start listening...</h3>
            <audio id="audio-player" controls>
                Your browser does not support the audio element.
            </audio>
            
            <div class="action-buttons">
                <a id="download-btn" href="#" class="btn btn-disabled" download>⬇ Download Track</a>
            </div>
        </div>

        <div class="playlist-header">
            <span>Library</span>
        </div>

        <ul class="playlist" id="playlist">
            <li data-src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3">
                <div class="song-info">
                    <span>Electronic Journey</span>
                    <span class="artist-name">SoundHelix Artist A</span>
                </div>
            </li>
            <li data-src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3">
                <div class="song-info">
                    <span>Chill Synth Beats</span>
                    <span class="artist-name">Creator B</span>
                </div>
            </li>
            <li data-src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3">
                <div class="song-info">
                    <span>Upbeat Open Source</span>
                    <span class="artist-name">Artist C</span>
                </div>
            </li>
        </ul>
    </div>

    <script>
        const audioPlayer = document.getElementById('audio-player');
        const trackTitleDisplay = document.getElementById('current-track-title');
        const playlistItems = document.querySelectorAll('#playlist li');
        const downloadBtn = document.getElementById('download-btn');

        playlistItems.forEach(item => {
            item.addEventListener('click', function() {
                // Remove active class from all items
                playlistItems.forEach(el => el.classList.remove('active'));
                
                // Add active class to clicked item
                this.classList.add('active');
                
                // Get the song URL and title
                const songUrl = this.getAttribute('data-src');
                const songTitle = this.querySelector('.song-info span:first-child').innerText;
                
                // Update player and play
                audioPlayer.src = songUrl;
                trackTitleDisplay.innerText = "Now Playing: " + songTitle;
                audioPlayer.play();

                // NEW: Update Download Button
                downloadBtn.href = songUrl;
                downloadBtn.classList.remove('btn-disabled');
                downloadBtn.classList.add('btn-download');
                downloadBtn.setAttribute('download', songTitle + '.mp3');
            });
        });

        // Automatically play the next song
        audioPlayer.addEventListener('ended', function() {
            let currentActive = document.querySelector('.playlist li.active');
            if (currentActive && currentActive.nextElementSibling) {
                currentActive.nextElementSibling.click();
            } else {
                playlistItems[0].click();
            }
        });
    </script>
</body>
</html>
